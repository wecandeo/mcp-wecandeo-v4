{
	"compilerOptions": {
		"target": "es2022",
		"lib": [
			"es2022"
		],
		"module": "Node16",
		"moduleResolution": "Node16",
		"resolveJsonModule": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"declaration": true,
		"noEmit": false,
		"isolatedModules": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"types": [
			"node"
		]
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
